# -*- coding: utf-8 -*-
"""
eFootball Turnir - Telegram bot (Web App ochuvchi)
"""

import asyncio
import logging
import os

from aiogram import Bot, Dispatcher, Router
from aiogram.client.default import DefaultBotProperties
from aiogram.enums import ParseMode
from aiogram.filters import CommandStart
from aiogram.types import (
    InlineKeyboardButton,
    InlineKeyboardMarkup,
    Message,
    WebAppInfo,
)

logging.basicConfig(level=logging.INFO)

router = Router()
WEBAPP_URL = os.getenv("WEBAPP_URL", "")


@router.message(CommandStart())
async def cmd_start(message: Message) -> None:
    if not WEBAPP_URL:
        await message.answer(
            "⚠️ WEBAPP_URL sozlanmagan. Admin backend'ni joylashtirib, "
            "shu manzilni bot muhitiga qo'shishi kerak."
        )
        return

    kb = InlineKeyboardMarkup(
        inline_keyboard=[
            [InlineKeyboardButton(text="🏆 Turnirni ochish", web_app=WebAppInfo(url=WEBAPP_URL))]
        ]
    )
    await message.answer(
        "⚽ <b>eFootball Turnir</b>ga xush kelibsiz!\n\n"
        "Liga tanlash, ro'yxatdan o'tish, jadval va reyting jadvalini "
        "ko'rish uchun quyidagi tugmani bosing 👇",
        reply_markup=kb,
    )


async def main() -> None:
    token = os.getenv("BOT_TOKEN")
    if not token:
        raise RuntimeError("BOT_TOKEN environment variable o'rnatilmagan!")

    bot = Bot(token=token, default=DefaultBotProperties(parse_mode=ParseMode.HTML))
    dp = Dispatcher()
    dp.include_router(router)

    logging.info("Bot ishga tushdi...")
    await dp.start_polling(bot)


if __name__ == "__main__":
    asyncio.run(main())
